# Android fstab file for TWRP
#<src>  <mnt_point>  <type>  <mnt_flags>  <fs_mgr_flags>
/dev/block/platform/13540000.dwmmc0/by-name/BOOT  /boot  emmc  defaults  defaults
/dev/block/platform/13540000.dwmmc0/by-name/RECOVERY  /recovery  emmc  defaults  defaults
/dev/block/platform/13540000.dwmmc0/by-name/CACHE  /cache  ext4  defaults  defaults
/dev/block/platform/13540000.dwmmc0/by-name/SYSTEM  /system  ext4  defaults  defaults
/dev/block/platform/13540000.dwmmc0/by-name/USERDATA  /data  f2fs  defaults  defaults
